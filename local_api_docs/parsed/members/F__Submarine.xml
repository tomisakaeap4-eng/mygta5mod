<?xml version="1.0" encoding="utf-8"?>
<member name="F:GTA.VehicleType.Submarine">
    
            
    <summary>
            The submarine type.
            </summary>
    
            
    <remarks>
        
            
        <para>
            Submarine cars are not classified as this type but classified as 
            <see cref="F:GTA.VehicleType.SubmarineCar"/>
            .
        </para>
        
            
        <para>
            The corresponding name in vehicles.meta for this value is 
            <c>VEHICLE_TYPE_TRAIN</c>
            .
        </para>
        
            
        <para>
            The internal class in memory is 
            <c>CSubmarine</c>
        </para>
        
            
    </remarks>
    
        
</member>
