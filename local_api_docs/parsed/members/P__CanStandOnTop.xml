    <value>
        
            
        <see langword="true"/>
         if 
        <see cref="T:GTA.Ped"/>
        s can stand on this 
        <see cref="T:GTA.Vehicle"/>
         regardless of 
        <see cref="T:GTA.Vehicle"/>
        s speed; otherwise, 
        <see langword="false"/>
        .
            
    </value>
    
        
</member>
