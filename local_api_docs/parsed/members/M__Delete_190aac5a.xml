<?xml version="1.0" encoding="utf-8"?>
<member name="M:GTA.Entity.Delete">
    
            
    <summary>
        
            
        <para>
            Destroys this 
            <see cref="T:GTA.Entity"/>
             and sets 
            <see cref="P:GTA.PoolObject.Handle"/>
             to 0.
        </para>
        
            
        <para>
            
            If you need to remove this 
            <see cref="T:GTA.Entity"/>
             from collections that use 
            <see cref="M:System.Object.Equals(System.Object)"/>
             for equality comparison (e.g. 
            <see cref="T:System.Collections.Generic.Dictionary`2"/>
            ),
            remove this 
            <see cref="T:GTA.Entity"/>
             element from these collections before calling this method.
            
        </para>
        
            
    </summary>
    
        
</member>
