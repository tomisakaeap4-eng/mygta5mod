<?xml version="1.0" encoding="utf-8"?>
<member name="M:GTA.Game.IsControlEnabled(GTA.Control)">
    
            
    <summary>
        
            Gets whether a 
        <see cref="T:GTA.Control"/>
         is enabled or disabled this frame.
            
    </summary>
    
            
    <param name="control">
        The 
        <see cref="T:GTA.Control"/>
         to check.
    </param>
    
            
    <returns>
        <see langword="true"/>
         if the 
        <see cref="T:GTA.Control"/>
         is Enabled; otherwise, 
        <see langword="false"/>
    </returns>
    
        
</member>
