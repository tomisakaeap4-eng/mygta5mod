        <see cref="T:GTA.Entity"/>
         is touching the 
        <see cref="T:GTA.Entity"/>
         
        <paramref name="entity"/>
        .
            
    </summary>
    
            
    <param name="entity">
        The 
        <see cref="T:GTA.Entity"/>
         to check.
    </param>
    
            
    <returns>
        
              
        <see langword="true"/>
         if this 
        <see cref="T:GTA.Entity"/>
         is touching 
        <paramref name="entity"/>
        ; otherwise, 
        <see langword="false"/>
        .
            
    </returns>
    
        
</member>
