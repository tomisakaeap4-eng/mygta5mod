<?xml version="1.0" encoding="utf-8"?>
<member name="M:GTA.Entity.IsNearEntity(GTA.Entity,GTA.Math.Vector3)">
    
            
    <summary>
        
            Determines whether this 
        <see cref="T:GTA.Entity"/>
         is near a specified 
        <see cref="T:GTA.Entity"/>
        .
            
    </summary>
    
            
    <param name="entity">
        The 
        <see cref="T:GTA.Entity"/>
         to check.
    </param>
    
            
    <param name="bounds">
        The max displacement from the 
        <paramref name="entity"/>
        .
    </param>
    
            
    <returns>
        
              
        <see langword="true"/>
         if this 
        <see cref="T:GTA.Entity"/>
         is near the 
        <paramref name="entity"/>
        ; otherwise, 
        <see langword="false"/>
        .
            
    </returns>
    
        
</member>
