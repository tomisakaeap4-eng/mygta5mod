<member name="M:GTA.Entity.IsAttached">
    
            
    <summary>
        
            Determines whether this 
        <see cref="T:GTA.Entity"/>
         is attached to any other 
        <see cref="T:GTA.Entity"/>
        .
            
    </summary>
    
            
    <returns>
        
              
        <see langword="true"/>
         if this 
        <see cref="T:GTA.Entity"/>
         is attached to another 
        <see cref="T:GTA.Entity"/>
        ; otherwise, 
        <see langword="false"/>
        .
            
    </returns>
    
        
</member>
