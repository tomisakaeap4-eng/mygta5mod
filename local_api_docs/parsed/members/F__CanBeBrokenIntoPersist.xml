<member name="F:GTA.VehicleLockStatus.CanBeBrokenIntoPersist">
    
            
    <summary>
        
            
        <para>
            The 
            <see cref="T:GTA.Vehicle"/>
             is locked and must be broken into.
        </para>
        
            
        <para>
            Even if the door the 
            <see cref="T:GTA.Ped"/>
             is entering through has its window broken, 
            <see cref="T:GTA.Ped"/>
            s will always have to try to break it and enter the 
            <see cref="T:GTA.Vehicle"/>
             consecutively.
        </para>
        
            
    </summary>
    
        
</member>
