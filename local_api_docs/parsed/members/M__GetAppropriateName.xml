<?xml version="1.0" encoding="utf-8"?>
<member name="M:GTA.Blip.GetAppropriateName">
    
            
    <summary>
        
            Gets the appropriate name of this 
        <see cref="T:GTA.Blip"/>
         in the same way the game does.
            
    </summary>
    
            
    <value>
        
            The same 
        <see cref="T:System.String"/>
         as 
        <see cref="P:GTA.Blip.Name"/>
         if the custom string is set;
            otherwise, the localized 
        <see cref="T:System.String"/>
         from the games language files with the same GXT key hash as 
        <see cref="P:GTA.Blip.DisplayNameHash"/>
        .
            
    </value>
    
            Returns 
    <see langword="null"/>
     if the 
    <see cref="T:GTA.Blip"/>
     does not exist.
        
</member>
