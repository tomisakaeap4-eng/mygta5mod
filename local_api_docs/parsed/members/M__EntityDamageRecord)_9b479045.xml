<?xml version="1.0" encoding="utf-8"?>
<member name="M:GTA.EntityDamageRecord.op_Equality(GTA.EntityDamageRecord,GTA.EntityDamageRecord)">
    
            
    <summary>
        
            Determines if two 
        <see cref="T:GTA.EntityDamageRecord"/>
        s have the same properties.
            
    </summary>
    
            
    <param name="left">
        The left 
        <see cref="T:GTA.Entity"/>
        .
    </param>
    
            
    <param name="right">
        The right 
        <see cref="T:GTA.Entity"/>
        .
    </param>
    
            
    <returns>
        <c>true</c>
         if 
        <paramref name="left"/>
         has the same properties as 
        <paramref name="right"/>
        ; otherwise, 
        <c>false</c>
        .
    </returns>
    
        
</member>
