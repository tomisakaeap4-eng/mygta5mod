<?xml version="1.0" encoding="utf-8"?>
<member name="F:GTA.VehicleType.Motorcycle">
    
            
    <summary>
            The motorcycle type.
            </summary>
    
            
    <remarks>
        
            
        <para>
            Tricycles are not classified as this type but classified as 
            <see cref="F:GTA.VehicleType.QuadBike"/>
            .
        </para>
        
            
        <para>
            The corresponding name in vehicles.meta for this value is 
            <c>VEHICLE_TYPE_BIKE</c>
            .
        </para>
        
            
        <para>
            The internal class in memory is 
            <c>CBike</c>
            .
        </para>
        
            
    </remarks>
    
        
</member>
