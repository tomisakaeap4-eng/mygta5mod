<?xml version="1.0" encoding="utf-8"?>
<member name="M:GTA.PedGroup.op_Equality(GTA.PedGroup,GTA.PedGroup)">
    
            
    <summary>
        
            Determines if two 
        <see cref="T:GTA.PedGroup"/>
        s refer to the same group.
            
    </summary>
    
            
    <param name="left">
        The left 
        <see cref="T:GTA.Checkpoint"/>
        .
    </param>
    
            
    <param name="right">
        The right 
        <see cref="T:GTA.Checkpoint"/>
        .
    </param>
    
            
    <returns>
        <see langword="true"/>
         if 
        <paramref name="left"/>
         is the same group as 
        <paramref name="right"/>
        ; otherwise, 
        <see langword="false"/>
        .
    </returns>
    
        
</member>
