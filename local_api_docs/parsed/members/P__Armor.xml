<?xml version="1.0" encoding="utf-8"?>
<member name="P:GTA.Ped.Armor">
    
            
    <summary>
        
            Gets or sets how much armor this 
        <see cref="T:GTA.Ped"/>
         is wearing as an 
        <see cref="T:System.Int32"/>
        .
            
    </summary>
    
            
    <remarks>
        if you need to get or set the value precisely, use 
        <see cref="P:GTA.Ped.ArmorFloat"/>
         instead.
    </remarks>
    
            
    <value>
        
            The armor as an 
        <see cref="T:System.Int32"/>
        .
            
    </value>
    
        
</member>
