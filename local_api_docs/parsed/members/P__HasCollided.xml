<?xml version="1.0" encoding="utf-8"?>
<member name="P:GTA.Entity.HasCollided">
    
            
    <summary>
        
            Gets a value indicating whether this 
        <see cref="T:GTA.Entity"/>
         has collided with anything.
            
    </summary>
    
            
    <value>
        
            
        <see langword="true"/>
         if this 
        <see cref="T:GTA.Entity"/>
         has collided; otherwise, 
        <see langword="false"/>
        .
            
    </value>
    
            
    <remarks>
        <see cref="P:GTA.Entity.IsRecordingCollisions"/>
         must be 
        <see langword="true"/>
         for this to work.
    </remarks>
    
        
</member>
