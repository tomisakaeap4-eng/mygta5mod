<?xml version="1.0" encoding="utf-8"?>
<member name="M:GTA.Building.FromHandle(System.Int32)">
    
            
    <summary>
        
            Creates a new instance of an 
        <see cref="T:GTA.Building"/>
         from the given handle.
            
    </summary>
    
            
    <param name="handle">The building handle.</param>
    
            
    <returns>
        
            Returns a 
        <see cref="T:GTA.Building"/>
         if this handle corresponds to a 
        <see cref="T:GTA.Building"/>
        .
            Returns 
        <see langword="null"/>
         if no 
        <see cref="T:GTA.Building"/>
         exists this the specified 
        <paramref name="handle"/>
        
            
    </returns>
    
        
</member>
