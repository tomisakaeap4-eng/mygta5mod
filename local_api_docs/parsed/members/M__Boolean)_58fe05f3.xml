<?xml version="1.0" encoding="utf-8"?>
<member name="M:GTA.World.CreateProp(GTA.Model,GTA.Math.Vector3,System.Boolean,System.Boolean)">
    
            
    <summary>
        
            Spawns a 
        <see cref="T:GTA.Prop"/>
         of the given 
        <see cref="T:GTA.Model"/>
         at the specified position.
            
    </summary>
    
            
    <param name="model">
        The 
        <see cref="T:GTA.Model"/>
         of the 
        <see cref="T:GTA.Prop"/>
        .
    </param>
    
            
    <param name="position">
        The position to spawn the 
        <see cref="T:GTA.Prop"/>
         at.
    </param>
    
            
    <param name="dynamic">
        if set to 
        <see langword="true"/>
         the 
        <see cref="T:GTA.Prop"/>
         will have physics; otherwise, it will be static.
    </param>
    
            
    <param name="placeOnGround">
        if set to 
        <see langword="true"/>
         place the prop on the ground nearest to the 
        <paramref name="position"/>
        .
    </param>
    
            
    <remarks>
        returns 
        <see langword="null"/>
         if the 
        <see cref="T:GTA.Prop"/>
         could not be spawned.
    </remarks>
    
        
</member>
