# Thư mục chứa file build (Tuyệt đối không push lên Git)
[Bb]in/
[Oo]bj/

# Thư mục ẩn và file cấu hình cá nhân của Visual Studio
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo

# File cache và file tạm
*.cache
*.Up2Date
*.txt.FileListAbsolute.txt

# ==========================================
# NuGet Packages
# ==========================================
*.nupkg
packages/
project.lock.json
.nuget/

# ==========================================
# Hệ điều hành (OS)
# ==========================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Mac (Nếu bạn có dùng chung với Mac)
.DS_Store

# logs/ được tạo bởi copy_gta_logs.ps1 khi copy logs. Không commit.
./logs

# local_api_docs/parsed/ do parse_local_api_docs.{sh,ps1} tạo ra: assembly.xml + members/<K>__<Name>.xml + index.json. Không commit.
local_api_docs/parsed/

# Thư mục api_docs/ chứa corpus API cho agent (clone bằng bootstrap_api_docs.ps1)
./api_docs

# Chặn git add -A kéo cả working tree của embedded git repos trong api_docs/
# (git xử lý thư mục có .git/ như embedded repo, vượt qua pattern ./api_docs ở trên).
api_docs/gta5-nativedb-data/
api_docs/scripthookvdotnet/
api_docs/scripthookvdotnet.wiki/
